@model proyecto_programacion_avanzada.ViewModels.Residente.ResidenteEditViewModel

@using proyecto_programacion_avanzada.Common.Enums

@{
    ViewBag.Title = "Editar Residente";
}

<h2>Editar Residente</h2>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    @Html.HiddenFor(m => m.IdResidente)

    <div class="form-horizontal">

        <hr />

        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

        <div class="form-group">
            @Html.LabelFor(m => m.Nombre)
            @Html.EditorFor(m => m.Nombre, new { htmlAttributes = new { @class = "form-control" } })
            @Html.ValidationMessageFor(m => m.Nombre)
        </div>

        <div class="form-group">
            @Html.LabelFor(m => m.FechaIngreso)
            @Html.TextBoxFor(m => m.FechaIngreso, "{0:yyyy-MM-dd}",
                new { @class = "form-control", type = "date" })
            @Html.ValidationMessageFor(m => m.FechaIngreso)
        </div>

        <div class="form-group">
            @Html.LabelFor(m => m.Estado)

            @Html.DropDownListFor(
                m => m.Estado,
                new SelectList(Enum.GetValues(typeof(EstadoGeneral))),
                "Seleccione un estado",
                new { @class = "form-control" })

            @Html.ValidationMessageFor(m => m.Estado)
        </div>

        <div class="form-group">
            <label>Usuario</label>

            @Html.DropDownListFor(
                m => m.IdUsuario,
                (SelectList)ViewBag.Usuarios,
                "Seleccione un usuario",
                new { @class = "form-control" })

            @Html.ValidationMessageFor(m => m.IdUsuario)
        </div>

        <div class="form-group">
            <label>Vivienda</label>

            @Html.DropDownListFor(
                m => m.IdVivienda,
                (IEnumerable<SelectListItem>)ViewBag.Viviendas,
                "Seleccione una vivienda",
                new { @class = "form-control" })

            @Html.ValidationMessageFor(m => m.IdVivienda)
        </div>

        <br />

        <input type="submit" value="Actualizar" class="btn btn-primary" />

        @Html.ActionLink("Volver", "Index", null, new { @class = "btn btn-secondary" })

    </div>
}