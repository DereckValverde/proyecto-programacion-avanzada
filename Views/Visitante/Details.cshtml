@model proyecto_programacion_avanzada.ViewModels.Visitante.VisitanteDetailsViewModel

@{
    ViewBag.Title = "Detalle del Visitante";
}

<h2>Detalle del Visitante</h2>

<div>
    <hr />

    <dl class="dl-horizontal">

        <dt>Nombre</dt>
        <dd>@Model.Nombre</dd>

        <dt>Identificación</dt>
        <dd>@Model.Identificacion</dd>

        <dt>Tipo</dt>
        <dd>@Model.Tipo</dd>

        <dt>Vivienda</dt>
        <dd>@Model.NombreVivienda</dd>

        <dt>Fecha de Ingreso</dt>
        <dd>@Model.FechaIngreso.ToString("g")</dd>

        <dt>Fecha de Salida</dt>
        <dd>@(Model.FechaSalida.HasValue ? Model.FechaSalida.Value.ToString("g") : "Aún dentro del condominio")</dd>

        <dt>Estado</dt>
        <dd>
            @if (Model.SeEncuentraDentro)
            {
                <span class="badge bg-success">Dentro</span>
            }
            else
            {
                <span class="badge bg-secondary">Salió</span>
            }
        </dd>

    </dl>
</div>

<p>
    @if (Model.SeEncuentraDentro)
    {
        @Html.ActionLink("Registrar salida", "RegistrarSalida", new { id = Model.IdVisitante }, new { @class = "btn btn-warning" })
    }
    @Html.ActionLink("Editar", "Edit", new { id = Model.IdVisitante }, new { @class = "btn btn-secondary" })
    @Html.ActionLink("Volver", "Index", null, new { @class = "btn btn-secondary" })
</p>
